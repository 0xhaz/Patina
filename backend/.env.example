# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Qwen / DashScope (Model Studio, Singapore endpoint) ---
# Get the key: Model Studio console (Singapore region) -> API-KEY -> Create.
DASHSCOPE_API_KEY=

# OpenAI-compatible base URL for the DashScope International (Singapore) endpoint.
# Confirm in console if this changes.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model IDs — CONFIRM exact IDs in the Model Studio console before locking.
# Defaults reflect architecture-patina.md; override here if the console lists different IDs.
QWEN_BACKBONE_MODEL=qwen3.7-plus
QWEN_OCR_MODEL=qwen-vl-ocr
QWEN_FLASH_MODEL=qwen-flash
QWEN_EMBED_MODEL=text-embedding-v4

# --- Database (local pgvector mirrors ApsaraDB RDS PostgreSQL) ---
DATABASE_URL=postgresql://patina:patina@localhost:5433/patina
